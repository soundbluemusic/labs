{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "soundblue-labs",
  "compatibility_date": "2026-05-25",
  // Static-only Worker: serves the Astro build output in ./dist.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  // Custom domain — wrangler attaches it on deploy (zone: soundbluemusic.com).
  "routes": [{ "pattern": "labs.soundbluemusic.com", "custom_domain": true }]
}
