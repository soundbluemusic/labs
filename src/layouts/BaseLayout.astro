---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import {
  defaultLocale,
  htmlLangAttr,
  locales,
  ogLocale,
  ui,
  type Locale,
} from "../i18n/ui";
import { localizePath } from "../i18n/utils";

interface Props {
  lang: Locale;
  title: string;
  description?: string;
  image?: string;
}

const { lang, title, description, image = "/og.png" } = Astro.props;
const dict = ui[lang];
const siteName = dict.siteName;
const desc = description ?? dict.siteDescription;

const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;

const alternates = locales.map((code) => ({
  code,
  href: new URL(localizePath(Astro.url.pathname, code), Astro.site).href,
}));
const xDefaultHref = new URL(
  localizePath(Astro.url.pathname, defaultLocale),
  Astro.site,
).href;
---

<!doctype html>
<html lang={htmlLangAttr[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#fafafa" />

    {
      alternates.map((alt) => (
        <link rel="alternate" hreflang={alt.code} href={alt.href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={xDefaultHref} />

    {/* Open Graph */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content={ogLocale[lang]} />
    {
      locales
        .filter((c) => c !== lang)
        .map((c) => (
          <meta property="og:locale:alternate" content={ogLocale[c]} />
        ))
    }
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={siteName} />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    <slot name="head" />
  </head>
  <body class="bg-bg text-fg flex min-h-screen flex-col antialiased">
    <Header lang={lang} />
    <main class="w-full flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
