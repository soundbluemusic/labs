---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolEmbed from '../../components/ToolEmbed.astro';
import { tools } from '../../data/tools';

export function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;
---

<BaseLayout title={tool.name} description={tool.tagline}>
  <article class="mx-auto max-w-5xl px-5 py-10">
    <a
      href="/"
      class="inline-flex items-center gap-1 text-sm text-slate-500 transition-colors hover:text-slate-900"
    >
      ← 모든 도구
    </a>

    <div class="mt-6 flex flex-wrap items-center gap-2">
      <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-500">
        {tool.category}
      </span>
      {
        tool.requiresLogin && (
          <span class="rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700">
            Claude 로그인 필요
          </span>
        )
      }
    </div>

    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">{tool.name}</h1>
    <p class="mt-3 max-w-2xl text-lg text-slate-600">{tool.tagline}</p>
    <p class="mt-4 max-w-2xl leading-relaxed text-slate-600">{tool.description}</p>

    {
      tool.requiresLogin && (
        <div class="mt-6 max-w-2xl rounded-xl border border-blue-200 bg-blue-50 p-4 text-sm text-blue-900">
          <p class="font-semibold">이 도구는 Claude 로그인이 필요합니다.</p>
          <p class="mt-1 leading-relaxed text-blue-800">
            도구가 Claude AI를 직접 호출하기 때문에, 아래 영역에서 도구를 쓰려면 Claude에 로그인되어
            있어야 합니다. 로그인되어 있지 않으면 로그인 안내가 표시됩니다. 생성에 드는 사용량은 본인
            Claude 계정에서 소모됩니다.{' '}
            <a
              class="font-medium underline"
              href="https://claude.ai/login"
              target="_blank"
              rel="noopener"
            >
              claude.ai 로그인 →
            </a>
          </p>
        </div>
      )
    }

    <div class="mt-8">
      <ToolEmbed tool={tool} />
    </div>

    <p class="mt-6 text-sm text-slate-400">
      원본 아티팩트:{' '}
      <a
        class="underline transition-colors hover:text-slate-600"
        href={tool.artifactUrl}
        target="_blank"
        rel="noopener"
      >
        claude.site에서 보기 ↗
      </a>
    </p>
  </article>
</BaseLayout>
