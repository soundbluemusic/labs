---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolEmbed from '../../components/ToolEmbed.astro';
import { tools } from '../../data/tools';

export function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
    props: { tool },
  }));
}

const { tool } = Astro.props;

const siteUrl = Astro.site?.href ?? 'https://labs.soundbluemusic.com/';
const toolUrl = new URL(`/tools/${tool.slug}`, siteUrl).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: tool.name,
      url: toolUrl,
      description: tool.description,
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Web',
      inLanguage: 'ko',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'KRW' },
      publisher: { '@type': 'Organization', name: 'soundbluemusic', url: siteUrl },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: '홈', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: tool.name, item: toolUrl },
      ],
    },
  ],
};
---

<BaseLayout title={tool.name} description={tool.tagline}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <article class="mx-auto max-w-5xl px-5 py-10">
    <a
      href="/"
      class="inline-flex items-center gap-1 text-sm text-muted transition-colors hover:text-fg"
    >
      ← 모든 도구
    </a>

    <div class="mt-6 flex flex-wrap items-center gap-2">
      <span class="rounded-full bg-line-subtle px-2.5 py-1 text-xs font-medium text-muted">
        {tool.category}
      </span>
      {
        tool.requiresLogin && (
          <span class="rounded-full bg-fg px-2.5 py-1 text-xs font-medium text-accent-fg">
            Claude 로그인 필요
          </span>
        )
      }
    </div>

    <h1 class="mt-3 text-3xl font-bold tracking-tight text-fg sm:text-4xl">{tool.name}</h1>
    <p class="mt-3 max-w-2xl text-lg text-muted">{tool.tagline}</p>
    <p class="mt-4 max-w-2xl leading-relaxed text-muted">{tool.description}</p>

    {
      tool.requiresLogin && (
        <div class="mt-6 max-w-2xl rounded-xl border border-accent-line bg-accent-soft p-4 text-sm">
          <p class="font-semibold text-fg">이 도구는 Claude 로그인이 필요합니다.</p>
          <p class="mt-1 leading-relaxed text-muted">
            도구가 Claude AI를 직접 호출하기 때문에, 아래 영역에서 도구를 쓰려면 Claude에 로그인되어
            있어야 합니다. 로그인되어 있지 않으면 로그인 안내가 표시됩니다. 생성에 드는 사용량은 본인
            Claude 계정에서 소모됩니다.{' '}
            <a
              class="font-medium text-accent-strong underline"
              href="https://claude.ai/login"
              target="_blank"
              rel="noopener"
            >
              claude.ai 로그인 →
            </a>
          </p>
        </div>
      )
    }

    <div class="mt-8">
      <ToolEmbed tool={tool} />
    </div>

    <p class="mt-6 text-sm text-faint">
      원본 아티팩트:{' '}
      <a
        class="underline transition-colors hover:text-muted"
        href={tool.artifactUrl}
        target="_blank"
        rel="noopener"
      >
        claude.site에서 보기 ↗
      </a>
    </p>
  </article>
</BaseLayout>
