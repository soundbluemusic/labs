---
import BaseLayout from '../layouts/BaseLayout.astro';
import Wordmark from '../components/Wordmark.astro';
import ToolCard from '../components/ToolCard.astro';
import { tools } from '../data/tools';

const siteUrl = Astro.site?.href ?? 'https://labs.soundbluemusic.com/';
const description =
  'Claude로 동작하는 도구 모음. 로그인하면 바로 쓸 수 있는 실험적인 도구들입니다.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: 'labs by soundbluemusic',
      description,
      inLanguage: 'ko',
      publisher: { '@id': `${siteUrl}#org` },
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#org`,
      name: 'soundbluemusic',
      url: siteUrl,
    },
  ],
};
---

<BaseLayout title="labs by soundbluemusic" description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <section class="mx-auto max-w-5xl px-5 pb-10 pt-16 sm:pt-24">
    <h1>
      <Wordmark size="lg" as="span" />
    </h1>
    <p class="mt-5 max-w-xl text-lg text-muted sm:text-xl">
      Claude로 동작하는 도구 모음. 로그인하면 바로 쓸 수 있는 실험적인 도구들입니다.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-20">
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>
</BaseLayout>
