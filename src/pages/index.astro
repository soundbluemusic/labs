---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import { tools } from '../data/tools';

const siteUrl = Astro.site?.href ?? 'https://labs.soundbluemusic.com/';
const description = 'Claude로 동작하는 도구. Claude에 로그인하면 바로 쓸 수 있습니다.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}#website`,
      url: siteUrl,
      name: 'labs by soundbluemusic',
      description,
      inLanguage: 'ko',
      publisher: { '@id': `${siteUrl}#org` },
    },
    {
      '@type': 'Organization',
      '@id': `${siteUrl}#org`,
      name: 'SoundBlueMusic',
      url: 'https://soundbluemusic.com',
    },
  ],
};
---

<BaseLayout title="labs by soundbluemusic" description={description}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <section class="mx-auto max-w-5xl px-5 pb-12 pt-20 sm:pt-28">
    <h1 class="text-4xl font-bold tracking-tight text-fg sm:text-5xl">
      Claude로 동작하는 도구
    </h1>
    <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted">
      Claude에 로그인하면 쓸 수 있는 도구 {tools.length}개. 아래에서 바로 시작하세요.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-24">
    <div class="mb-6 flex items-baseline justify-between border-b border-line pb-3">
      <h2 class="text-sm font-semibold tracking-wide text-muted">도구</h2>
      <span class="text-sm tabular-nums text-faint">{tools.length}개</span>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {tools.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>
</BaseLayout>
