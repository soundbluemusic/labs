---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ui, locales } from '../i18n/ui';

const title = ui.ko.notFoundPageTitle;
const description = ui.ko.notFoundPageDescription;
---

<BaseLayout lang="ko" title={title} description={description}>
  <section class="mx-auto flex max-w-5xl flex-col items-center px-5 py-24 text-center">
    <p class="text-sm font-semibold text-accent">404</p>

    {
      locales.map((code) => (
        <div lang={code} class="mt-6 first:mt-2">
          <h1 class="text-2xl font-bold tracking-tight text-fg sm:text-3xl first:sm:text-4xl">
            {ui[code].notFoundTitle}
          </h1>
          <p class="mt-2 text-muted">{ui[code].notFoundLead}</p>
          <a
            href={code === 'ko' ? '/' : `/${code}/`}
            class="mt-4 inline-flex items-center gap-1 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-accent-fg transition-colors hover:bg-accent-strong"
          >
            {ui[code].notFoundHome}
          </a>
        </div>
      ))
    }
  </section>

  <script is:inline>
    // Best-effort: if the URL starts with /en/ or /ja/, redirect the 404 page lang context too.
    (function () {
      const seg = location.pathname.split('/').filter(Boolean)[0];
      if (seg === 'en' || seg === 'ja') {
        document.documentElement.lang = seg;
      }
    })();
  </script>
</BaseLayout>
