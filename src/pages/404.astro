---
import BaseLayout from "../layouts/BaseLayout.astro";
import { ui, locales } from "../i18n/ui";

const title = ui.ko.notFoundPageTitle;
const description = ui.ko.notFoundPageDescription;
---

<BaseLayout lang="ko" title={title} description={description}>
  <section
    class="mx-auto flex max-w-5xl flex-col items-center px-5 py-24 text-center"
  >
    <p class="text-accent text-sm font-semibold">404</p>

    {
      locales.map((code) => (
        <div lang={code} class="mt-6 first:mt-2">
          <h1 class="text-fg text-2xl font-bold tracking-tight sm:text-3xl first:sm:text-4xl">
            {ui[code].notFoundTitle}
          </h1>
          <p class="text-muted mt-2">{ui[code].notFoundLead}</p>
          <a
            href={code === "ko" ? "/" : `/${code}/`}
            class="bg-accent text-accent-fg hover:bg-accent-strong mt-4 inline-flex items-center gap-1 rounded-lg px-4 py-2 text-sm font-medium transition-colors"
          >
            {ui[code].notFoundHome}
          </a>
        </div>
      ))
    }
  </section>

  <script is:inline>
    // Best-effort: if the URL starts with /en/ or /ja/, redirect the 404 page lang context too.
    (function () {
      const seg = location.pathname.split("/").filter(Boolean)[0];
      if (seg === "en" || seg === "ja") {
        document.documentElement.lang = seg;
      }
    })();
  </script>
</BaseLayout>
