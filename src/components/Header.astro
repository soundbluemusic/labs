---
import Wordmark from "./Wordmark.astro";
import LangSwitcher from "./LangSwitcher.astro";
import { localizePath } from "../i18n/utils";
import type { Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const homeHref = localizePath("/", lang);
---

<header
  class="border-line/70 bg-bg/80 sticky top-0 z-30 border-b backdrop-blur"
>
  <div class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3">
    <Wordmark size="sm" href={homeHref} />
    <LangSwitcher lang={lang} />
  </div>
</header>
