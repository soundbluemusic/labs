---
import type { Tool } from '../data/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;

// Deterministic "voice waveform" bar heights (0–1) for the visual panel.
const bars = [
  0.2, 0.45, 0.3, 0.7, 0.5, 0.85, 0.4, 0.6, 0.95, 0.55, 0.35, 0.75, 0.5, 0.9, 0.3, 0.65, 0.45,
  0.8, 0.6, 1, 0.5, 0.7, 0.35, 0.55, 0.85, 0.4, 0.7, 0.3, 0.6, 0.9, 0.45, 0.75, 0.5, 0.65, 0.95,
  0.4, 0.55, 0.8, 0.35, 0.7, 0.5, 0.6, 0.85, 0.3, 0.65, 0.45, 0.75, 0.55, 0.9, 0.4, 0.6, 0.3,
  0.7, 0.5, 0.45, 0.25,
];
---

<a href={`/tools/${tool.slug}`} class="group block">
  <div
    class="grid overflow-hidden rounded-3xl border border-line bg-surface shadow-sm transition duration-200 hover:-translate-y-0.5 hover:shadow-lg md:grid-cols-2"
  >
    <div class="flex flex-col justify-between gap-8 p-8 sm:p-10">
      <div>
        <div class="flex flex-wrap items-center gap-2">
          <span class="rounded-full bg-line-subtle px-2.5 py-1 text-xs font-medium text-muted">
            {tool.category}
          </span>
          {
            tool.requiresLogin && (
              <span class="rounded-full bg-fg px-2.5 py-1 text-xs font-medium text-accent-fg">
                Claude 로그인 필요
              </span>
            )
          }
        </div>
        <h3 class="mt-5 text-2xl font-bold tracking-tight text-fg sm:text-3xl">{tool.name}</h3>
        <p class="mt-3 max-w-md leading-relaxed text-muted">{tool.tagline}</p>
      </div>
      <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-fg">
        도구 열기
        <svg
          class="h-4 w-4 transition-transform duration-200 group-hover:translate-x-1"
          viewBox="0 0 20 20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          aria-hidden="true"
        >
          <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
      </span>
    </div>

    <div class="relative hidden items-center justify-center overflow-hidden bg-fg p-10 md:flex">
      <svg
        class="h-28 w-full max-w-sm text-bg"
        viewBox="0 0 560 120"
        preserveAspectRatio="none"
        aria-hidden="true"
      >
        {
          bars.map((h, i) => (
            <rect
              x={i * 10 + 2}
              y={60 - h * 50}
              width="5"
              height={h * 100}
              rx="2.5"
              fill="currentColor"
              opacity={0.35 + h * 0.5}
            />
          ))
        }
      </svg>
    </div>
  </div>
</a>
