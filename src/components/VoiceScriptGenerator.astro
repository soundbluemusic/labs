---
import type { Locale } from "../i18n/ui";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;

// 컴포넌트 자체 i18n (생성기 UI 문자열). 번들 스크립트는 data 속성으로 읽음.
const gdict = {
  ko: {
    offline: "오프라인 · 로그인 불필요",
    generate: "대본 생성",
    generating: "생성 중…",
    regenerate: "다시 생성",
    download: "다운로드 (.txt)",
    intro:
      "버튼을 누르면 브라우저에서 바로 약 200개의 한국어 대화 대본을 생성합니다. 모든 발음이 골고루 들어가도록 음소 균형을 맞춥니다. 인터넷·로그인 없이 동작해요.",
    statDialogues: "대화",
    statTurns: "턴",
    statSyllables: "음절",
    covTitle: "발음 커버리지",
    cho: "초성",
    jung: "중성",
    fin: "종성",
    rare: "희귀자모",
    dialogue: "대화",
  },
  en: {
    offline: "Offline · no login",
    generate: "Generate script",
    generating: "Generating…",
    regenerate: "Regenerate",
    download: "Download (.txt)",
    intro:
      "Press the button to generate ~200 Korean dialogue scripts right in your browser, phoneme-balanced so every sound is covered. Works with no internet and no login.",
    statDialogues: "dialogues",
    statTurns: "turns",
    statSyllables: "syllables",
    covTitle: "Phoneme coverage",
    cho: "Onset",
    jung: "Nucleus",
    fin: "Coda",
    rare: "Rare jamo",
    dialogue: "Dialogue",
  },
  ja: {
    offline: "オフライン・ログイン不要",
    generate: "台本を生成",
    generating: "生成中…",
    regenerate: "再生成",
    download: "ダウンロード (.txt)",
    intro:
      "ボタンを押すと、ブラウザ上で約200本の韓国語対話台本をすぐに生成します。すべての発音が均等に入るよう音素バランスを取ります。ネット・ログインなしで動作します。",
    statDialogues: "対話",
    statTurns: "ターン",
    statSyllables: "音節",
    covTitle: "発音カバレッジ",
    cho: "初声",
    jung: "中声",
    fin: "終声",
    rare: "希少字母",
    dialogue: "対話",
  },
}[lang];
---

<div
  id="vsg-root"
  class="border-line bg-surface overflow-hidden rounded-2xl border shadow-sm"
  data-strings={JSON.stringify(gdict)}
>
  <div
    class="border-line-subtle flex items-center justify-between gap-2 border-b px-4 py-2.5"
  >
    <span class="text-faint truncate font-mono text-xs">voice-script-generator</span>
    <span
      class="bg-line-subtle text-muted shrink-0 rounded-full px-2.5 py-1 text-xs font-medium"
    >
      {gdict.offline}
    </span>
  </div>

  {/* 시작 화면 */}
  <div id="vsg-start" class="px-6 py-14 text-center">
    <p class="text-muted mx-auto mb-8 max-w-md text-sm leading-relaxed">
      {gdict.intro}
    </p>
    <button
      id="vsg-generate"
      type="button"
      class="bg-accent text-accent-fg hover:bg-accent-strong inline-flex items-center gap-2 rounded-xl px-8 py-4 text-base font-semibold shadow-sm transition-colors"
    >
      {gdict.generate}
    </button>
  </div>

  {/* 결과 화면 */}
  <div id="vsg-result" hidden>
    <div
      class="border-line-subtle flex flex-wrap items-center justify-between gap-3 border-b px-4 py-3"
    >
      <div id="vsg-stats" class="text-fg text-sm font-medium"></div>
      <div class="flex shrink-0 items-center gap-2">
        <button
          id="vsg-regenerate"
          type="button"
          class="border-line text-muted hover:bg-line-subtle hover:text-fg rounded-lg border px-3 py-1.5 text-sm font-medium transition-colors"
        >
          {gdict.regenerate}
        </button>
        <button
          id="vsg-download"
          type="button"
          class="bg-fg text-bg hover:opacity-90 rounded-lg px-4 py-1.5 text-sm font-semibold transition-opacity"
        >
          {gdict.download}
        </button>
      </div>
    </div>

    <div
      id="vsg-coverage"
      class="border-line-subtle bg-bg flex flex-wrap items-center gap-x-4 gap-y-1.5 border-b px-4 py-2.5 text-xs"
    >
    </div>

    <div id="vsg-list" class="max-h-[70vh] overflow-y-auto px-6 py-4"></div>
  </div>
</div>

<script>
  import { generate, formatScript } from "../lib/voice-script/generate";

  const root = document.getElementById("vsg-root");
  if (root) {
    const S = JSON.parse(root.dataset.strings || "{}");
    const startEl = document.getElementById("vsg-start")!;
    const resultEl = document.getElementById("vsg-result")!;
    const genBtn = document.getElementById("vsg-generate") as HTMLButtonElement;
    const reBtn = document.getElementById("vsg-regenerate") as HTMLButtonElement;
    const dlBtn = document.getElementById("vsg-download") as HTMLButtonElement;
    const statsEl = document.getElementById("vsg-stats")!;
    const covEl = document.getElementById("vsg-coverage")!;
    const listEl = document.getElementById("vsg-list")!;

    let current: ReturnType<typeof generate> | null = null;

    const fmtCov = (label: string, met: number, total: number) => {
      const ok = met >= total;
      const color = ok ? "text-emerald-600" : "text-amber-600";
      return `<span class="text-muted">${label}</span> <span class="font-mono font-semibold ${color}">${met}/${total}</span>`;
    };

    function render(script: NonNullable<typeof current>) {
      statsEl.innerHTML =
        `<span class="font-mono">${script.totalDialogues}</span> ${S.statDialogues} · ` +
        `<span class="font-mono">${script.totalTurns}</span> ${S.statTurns} · ` +
        `<span class="font-mono">${script.totalSyllables.toLocaleString()}</span> ${S.statSyllables}`;

      const c = script.coverage;
      const rareOk = c.l2.filter((x) => x.present).length;
      covEl.innerHTML =
        `<span class="text-faint font-medium">${S.covTitle}:</span>` +
        fmtCov(S.cho, c.cho.met, c.cho.total) +
        fmtCov(S.jung, c.jung.met, c.jung.total) +
        fmtCov(S.fin, c.fin.met, c.fin.total) +
        fmtCov(S.rare, rareOk, c.l2.length);

      listEl.innerHTML = script.dialogues
        .map((d, i) => {
          const turns = d.turns
            .map((t, j) => {
              const sp = d.speakers[j] || (j % 2 === 0 ? "A" : "B");
              const color = sp === "A" ? "text-blue-500" : "text-rose-500";
              return (
                `<div class="flex gap-2 pl-3">` +
                `<span class="${color} w-4 shrink-0 pt-0.5 text-xs font-bold">${sp}</span>` +
                `<span class="text-fg flex-1">${t}</span></div>`
              );
            })
            .join("");
          return (
            `<div class="mb-5">` +
            `<div class="text-faint mb-1 font-mono text-[10px]">${S.dialogue} ${i + 1}</div>` +
            `<div class="border-line-subtle space-y-1 border-l-2 pl-1">${turns}</div></div>`
          );
        })
        .join("");
    }

    function run() {
      genBtn.disabled = true;
      reBtn.disabled = true;
      const prev = genBtn.textContent;
      genBtn.textContent = S.generating;
      // 다음 프레임에서 계산 (버튼 상태가 먼저 반영되도록)
      setTimeout(() => {
        current = generate({ targetCount: 200, minCoverage: 10 });
        render(current);
        startEl.hidden = true;
        resultEl.hidden = false;
        genBtn.disabled = false;
        reBtn.disabled = false;
        genBtn.textContent = prev;
      }, 16);
    }

    genBtn.addEventListener("click", run);
    reBtn.addEventListener("click", run);
    dlBtn.addEventListener("click", () => {
      if (!current) return;
      const blob = new Blob([formatScript(current)], { type: "text/plain;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = "voice_script.txt";
      a.click();
      URL.revokeObjectURL(url);
    });
  }
</script>
