---
import type { Locale } from "../i18n/ui";
import curated from "../lib/voice-script/curated.json";
import { coverageVector, CHO, JUNG, REP_FINALS } from "../lib/voice-script/coverage";
import { buildTargets } from "../lib/voice-script/select";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;

// 빌드 타임에 커버리지 계산 → 정적 렌더 (보기엔 JS 불필요)
const totals: Record<string, number> = {};
for (const d of curated.dialogues) {
  const v = coverageVector(d.turns.join(" "));
  for (const k in v) totals[k] = (totals[k] || 0) + v[k];
}
const tg = buildTargets(10);
const grp = (list: readonly string[], pre: string) => ({
  met: list.filter((c) => (totals[pre + c] || 0) >= tg[pre + c]).length,
  total: list.length,
});
const cov = { cho: grp(CHO, "I_"), jung: grp(JUNG, "M_"), fin: grp(REP_FINALS, "F_") };

// 다운로드용 텍스트 (정적 임베드)
const scriptText = curated.dialogues
  .map((d, i) => `[대화 ${i + 1}]\n` + d.turns.map((t, j) => `${d.speakers[j] || (j % 2 === 0 ? "A" : "B")}: ${t}`).join("\n"))
  .join("\n\n");

const g = {
  ko: {
    offline: "오프라인 · 로그인 불필요",
    intro: `도구1로 생성한 대화를 원어민 리뷰어 3인이 0.1~5.0점으로 정밀 채점해, 자연스럽고 반응이 살아있는 상위만 엄선한 녹음 대본입니다. 소리 내어 읽어 음성 복제(TTS) 학습용으로 쓰세요.`,
    stat: "대화",
    min: "분",
    syl: "음절",
    cov: "발음 커버리지",
    cho: "초성", jung: "중성", fin: "종성",
    download: "전체 다운로드 (.txt)",
    copy: "복사",
    copied: "복사됨!",
    dialogue: "대화",
    scoreUnit: "점",
  },
  en: {
    offline: "Offline · no login",
    intro: `A recording script curated from Tool 1's dialogues, each precisely scored 0.1–5.0 by three native-speaker reviewers — only the top, natural, genuinely reactive ones are kept. Read it aloud for TTS / voice-cloning training.`,
    stat: "dialogues",
    min: "min",
    syl: "syllables",
    cov: "Phoneme coverage",
    cho: "Onset", jung: "Nucleus", fin: "Coda",
    download: "Download all (.txt)",
    copy: "Copy",
    copied: "Copied!",
    dialogue: "Dialogue",
    scoreUnit: "",
  },
  ja: {
    offline: "オフライン・ログイン不要",
    intro: `ツール1の対話をネイティブ3人が0.1〜5.0で精密採点し、自然で反応が生きている上位だけを厳選した録音台本です。音読してTTS・音声クローニング学習にお使いください。`,
    stat: "対話",
    min: "分",
    syl: "音節",
    cov: "発音カバレッジ",
    cho: "初声", jung: "中声", fin: "終声",
    download: "全部ダウンロード (.txt)",
    copy: "コピー",
    copied: "コピーしました!",
    dialogue: "対話",
    scoreUnit: "点",
  },
}[lang];

const minutes = `${curated.estMinutes.normal.toFixed(0)}~${curated.estMinutes.slow.toFixed(0)}`;
const covCls = (met: number, total: number) => (met >= total ? "text-emerald-600" : "text-amber-600");
---

<div id="vsg-root" class="border-line bg-surface overflow-hidden rounded-2xl border shadow-sm" data-script={scriptText}>
  <div class="border-line-subtle flex items-center justify-between gap-2 border-b px-4 py-2.5">
    <span class="text-faint truncate font-mono text-xs">recording-script · curated</span>
    <span class="bg-line-subtle text-muted shrink-0 rounded-full px-2.5 py-1 text-xs font-medium">{g.offline}</span>
  </div>

  <div class="px-6 pt-6">
    <p class="text-muted mb-4 max-w-2xl text-sm leading-relaxed">{g.intro}</p>
  </div>

  <div class="border-line-subtle flex flex-wrap items-center justify-between gap-3 border-y px-4 py-3">
    <div class="text-fg text-sm font-medium">
      <span class="font-mono">{curated.count}</span> {g.stat} ·{" "}
      <span class="font-mono">{minutes}</span> {g.min} ·{" "}
      <span class="font-mono">{curated.syllables.toLocaleString()}</span> {g.syl} ·{" "}
      <span class="text-emerald-600">≥<span class="font-mono">{curated.cutScore.toFixed(1)}</span>{g.scoreUnit}</span>
    </div>
    <div class="flex shrink-0 items-center gap-2">
      <button id="vsg-copy" type="button" data-copy={g.copy} data-copied={g.copied} class="border-line text-muted hover:bg-line-subtle hover:text-fg rounded-lg border px-4 py-1.5 text-sm font-medium transition-colors">
        {g.copy}
      </button>
      <button id="vsg-download" type="button" class="bg-fg text-bg hover:opacity-90 rounded-lg px-4 py-1.5 text-sm font-semibold transition-opacity">
        {g.download}
      </button>
    </div>
  </div>

  <div class="border-line-subtle bg-bg flex flex-wrap items-center gap-x-4 gap-y-1.5 border-b px-4 py-2.5 text-xs">
    <span class="text-faint font-medium">{g.cov}:</span>
    <span><span class="text-muted">{g.cho}</span> <span class={`font-mono font-semibold ${covCls(cov.cho.met, cov.cho.total)}`}>{cov.cho.met}/{cov.cho.total}</span></span>
    <span><span class="text-muted">{g.jung}</span> <span class={`font-mono font-semibold ${covCls(cov.jung.met, cov.jung.total)}`}>{cov.jung.met}/{cov.jung.total}</span></span>
    <span><span class="text-muted">{g.fin}</span> <span class={`font-mono font-semibold ${covCls(cov.fin.met, cov.fin.total)}`}>{cov.fin.met}/{cov.fin.total}</span></span>
  </div>

  <div class="max-h-[70vh] overflow-y-auto px-6 py-4">
    {
      curated.dialogues.map((d, i) => (
        <div class="mb-5">
          <div class="text-faint mb-1 flex items-center gap-2 font-mono text-[10px]">
            <span>{g.dialogue} {i + 1}</span>
            <span class="bg-line-subtle text-muted rounded px-1.5 py-0.5">{d.register}</span>
            <span class="text-emerald-600">{d.score.toFixed(1)}{g.scoreUnit}</span>
          </div>
          <div class="border-line-subtle space-y-1 border-l-2 pl-1 font-serif text-[15px] leading-relaxed">
            {d.turns.map((t, j) => (
              <div class="flex gap-2 pl-3">
                <span class={`w-4 shrink-0 pt-0.5 text-xs font-bold ${d.speakers[j] === "B" ? "text-rose-500" : "text-blue-500"}`}>
                  {d.speakers[j] || (j % 2 === 0 ? "A" : "B")}
                </span>
                <span class="text-fg flex-1">{t}</span>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</div>

<script>
  const root = document.getElementById("vsg-root");
  document.getElementById("vsg-download")?.addEventListener("click", () => {
    const text = root?.dataset.script || "";
    const blob = new Blob([text], { type: "text/plain;charset=utf-8" });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = "recording_script_30min.txt";
    a.click();
    URL.revokeObjectURL(url);
  });

  const copyBtn = document.getElementById("vsg-copy") as HTMLButtonElement | null;
  copyBtn?.addEventListener("click", async () => {
    const text = root?.dataset.script || "";
    try {
      await navigator.clipboard.writeText(text);
    } catch {
      const ta = document.createElement("textarea");
      ta.value = text;
      ta.style.position = "fixed";
      ta.style.opacity = "0";
      document.body.appendChild(ta);
      ta.select();
      document.execCommand("copy");
      document.body.removeChild(ta);
    }
    const done = copyBtn.dataset.copied || "Copied!";
    const label = copyBtn.dataset.copy || "Copy";
    copyBtn.textContent = done;
    copyBtn.classList.add("text-emerald-600");
    setTimeout(() => {
      copyBtn.textContent = label;
      copyBtn.classList.remove("text-emerald-600");
    }, 1500);
  });
</script>
