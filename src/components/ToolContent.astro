---
import BaseLayout from "../layouts/BaseLayout.astro";
import ToolEmbed from "./ToolEmbed.astro";
import type { Tool } from "../data/tools";
import { localizePath, t } from "../i18n/utils";
import { dateLocale, htmlLangAttr, type Locale } from "../i18n/ui";

interface Props {
  tool: Tool;
  lang: Locale;
}

const { tool, lang } = Astro.props;
const dict = t(lang);

const updatedDisplay = new Intl.DateTimeFormat(dateLocale[lang], {
  year: "numeric",
  month: "long",
  day: "numeric",
  timeZone: "UTC",
}).format(new Date(tool.updatedAt));

const siteUrl = Astro.site?.href ?? "https://labs.soundbluemusic.com/";
const toolPath = localizePath(`/tools/${tool.slug}`, lang);
const toolUrl = new URL(toolPath, siteUrl).href;
const homeHref = localizePath("/", lang);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebApplication",
      name: tool.name[lang],
      url: toolUrl,
      description: tool.description[lang],
      applicationCategory: "MultimediaApplication",
      operatingSystem: "Web",
      inLanguage: htmlLangAttr[lang],
      dateModified: tool.updatedAt,
      isAccessibleForFree: true,
      offers: { "@type": "Offer", price: "0", priceCurrency: "KRW" },
      publisher: {
        "@type": "Organization",
        name: "soundbluemusic",
        url: siteUrl,
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        {
          "@type": "ListItem",
          position: 1,
          name: dict.breadcrumbHome,
          item: new URL(homeHref, siteUrl).href,
        },
        {
          "@type": "ListItem",
          position: 2,
          name: tool.name[lang],
          item: toolUrl,
        },
      ],
    },
  ],
};
---

<BaseLayout
  lang={lang}
  title={tool.name[lang]}
  description={tool.tagline[lang]}
>
  <script
    type="application/ld+json"
    slot="head"
    set:html={JSON.stringify(jsonLd)}
  />

  <article class="mx-auto max-w-5xl px-5 py-10">
    <a
      href={homeHref}
      class="text-muted hover:text-fg inline-flex items-center gap-1 text-sm transition-colors"
    >
      {dict.backToTools}
    </a>

    <div class="mt-6 flex flex-wrap items-center gap-2">
      <span
        class="bg-line-subtle text-muted rounded-full px-2.5 py-1 text-xs font-medium"
      >
        {tool.category[lang]}
      </span>
      {
        tool.requiresLogin && (
          <span class="bg-fg text-accent-fg rounded-full px-2.5 py-1 text-xs font-medium">
            {dict.cardRequiresLogin}
          </span>
        )
      }
    </div>

    <h1 class="text-fg mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
      {tool.name[lang]}
    </h1>
    <p class="text-muted mt-3 max-w-2xl text-lg">{tool.tagline[lang]}</p>
    <p class="text-muted mt-4 max-w-2xl leading-relaxed">
      {tool.description[lang]}
    </p>
    <p class="text-faint mt-4 text-sm">
      {dict.toolUpdatedAt} ·{" "}
      <time datetime={tool.updatedAt}>{updatedDisplay}</time>
    </p>

    {
      tool.requiresLogin && (
        <div class="border-accent-line bg-accent-soft mt-6 max-w-2xl rounded-xl border p-4 text-sm">
          <p class="text-fg font-semibold">{dict.toolRequiresLoginTitle}</p>
          <p class="text-muted mt-1 leading-relaxed">
            {dict.toolRequiresLoginBody}
          </p>
          <p class="text-muted mt-2 leading-relaxed">
            {dict.toolRequiresLoginHint}
          </p>
          <div class="mt-4 flex flex-wrap items-center gap-2">
            <a
              class="bg-accent text-accent-fg hover:bg-accent-strong inline-flex items-center gap-1.5 rounded-lg px-5 py-3 text-base font-semibold shadow-sm transition-colors"
              href={tool.artifactUrl}
              target="_blank"
              rel="noopener"
            >
              {dict.toolOpenInClaude}
            </a>
          </div>
        </div>
      )
    }

    <div class="mt-8">
      <ToolEmbed tool={tool} lang={lang} />
    </div>

    <p class="text-faint mt-6 text-sm">
      {dict.toolSourceLabel}{" "}
      <a
        class="hover:text-muted underline transition-colors"
        href={tool.artifactUrl}
        target="_blank"
        rel="noopener"
      >
        {dict.toolSourceLink}
      </a>
    </p>
  </article>
</BaseLayout>
