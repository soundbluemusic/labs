---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolEmbed from './ToolEmbed.astro';
import type { Tool } from '../data/tools';
import { localizePath, t } from '../i18n/utils';
import { htmlLangAttr, type Locale } from '../i18n/ui';

interface Props {
  tool: Tool;
  lang: Locale;
}

const { tool, lang } = Astro.props;
const dict = t(lang);

const siteUrl = Astro.site?.href ?? 'https://labs.soundbluemusic.com/';
const toolPath = localizePath(`/tools/${tool.slug}`, lang);
const toolUrl = new URL(toolPath, siteUrl).href;
const homeHref = localizePath('/', lang);

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: tool.name[lang],
      url: toolUrl,
      description: tool.description[lang],
      applicationCategory: 'MultimediaApplication',
      operatingSystem: 'Web',
      inLanguage: htmlLangAttr[lang],
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'KRW' },
      publisher: { '@type': 'Organization', name: 'soundbluemusic', url: siteUrl },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: dict.breadcrumbHome, item: new URL(homeHref, siteUrl).href },
        { '@type': 'ListItem', position: 2, name: tool.name[lang], item: toolUrl },
      ],
    },
  ],
};
---

<BaseLayout lang={lang} title={tool.name[lang]} description={tool.tagline[lang]}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(jsonLd)} />

  <article class="mx-auto max-w-5xl px-5 py-10">
    <a
      href={homeHref}
      class="inline-flex items-center gap-1 text-sm text-muted transition-colors hover:text-fg"
    >
      {dict.backToTools}
    </a>

    <div class="mt-6 flex flex-wrap items-center gap-2">
      <span class="rounded-full bg-line-subtle px-2.5 py-1 text-xs font-medium text-muted">
        {tool.category[lang]}
      </span>
      {
        tool.requiresLogin && (
          <span class="rounded-full bg-fg px-2.5 py-1 text-xs font-medium text-accent-fg">
            {dict.cardRequiresLogin}
          </span>
        )
      }
    </div>

    <h1 class="mt-3 text-3xl font-bold tracking-tight text-fg sm:text-4xl">{tool.name[lang]}</h1>
    <p class="mt-3 max-w-2xl text-lg text-muted">{tool.tagline[lang]}</p>
    <p class="mt-4 max-w-2xl leading-relaxed text-muted">{tool.description[lang]}</p>

    {
      tool.requiresLogin && (
        <div class="mt-6 max-w-2xl rounded-xl border border-accent-line bg-accent-soft p-4 text-sm">
          <p class="font-semibold text-fg">{dict.toolRequiresLoginTitle}</p>
          <p class="mt-1 leading-relaxed text-muted">
            {dict.toolRequiresLoginBody}{' '}
            <a
              class="font-medium text-accent-strong underline"
              href="https://claude.ai/login"
              target="_blank"
              rel="noopener"
            >
              {dict.toolRequiresLoginCTA}
            </a>
          </p>
        </div>
      )
    }

    <div class="mt-8">
      <ToolEmbed tool={tool} lang={lang} />
    </div>

    <p class="mt-6 text-sm text-faint">
      {dict.toolSourceLabel}{' '}
      <a
        class="underline transition-colors hover:text-muted"
        href={tool.artifactUrl}
        target="_blank"
        rel="noopener"
      >
        {dict.toolSourceLink}
      </a>
    </p>
  </article>
</BaseLayout>
