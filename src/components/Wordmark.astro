---
interface Props {
  size?: 'sm' | 'lg';
  as?: 'a' | 'span';
  class?: string;
}

const { size = 'sm', as = 'a', class: className = '' } = Astro.props;

const labsCls = size === 'lg' ? 'text-6xl sm:text-7xl' : 'text-2xl';
const byCls = size === 'lg' ? 'text-base sm:text-lg' : 'text-xs';

const isLink = as === 'a';
const Tag = as;
---

<Tag
  href={isLink ? '/' : undefined}
  class:list={['group inline-flex items-baseline gap-2 no-underline', className]}
  aria-label={isLink ? 'labs by soundbluemusic — 홈' : undefined}
>
  <span class:list={['font-extrabold tracking-tight text-fg', labsCls]}>labs</span>
  <span class:list={['font-medium text-faint lowercase', byCls]}>
    by sound<span class="text-accent">blue</span>music
  </span>
</Tag>
