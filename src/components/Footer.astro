  <div
    class="mx-auto flex max-w-5xl flex-col gap-4 px-5 py-10 text-sm text-faint sm:flex-row sm:items-center sm:justify-between"
  >
    <Wordmark size="sm" />
    <p>© {year} soundbluemusic</p>
  </div>
</footer>
