---
import type { Tool } from '../data/tools';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
---

<div class="tool-embed overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
  <div class="flex items-center justify-between gap-2 border-b border-slate-100 px-4 py-2.5">
    <span class="truncate font-mono text-xs text-slate-400">{tool.slug}</span>
    <div class="flex shrink-0 items-center gap-1">
      <button
        type="button"
        data-fullscreen
        class="rounded-md px-2.5 py-1.5 text-xs font-medium text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900"
      >
        전체화면
      </button>
      <a
        href={tool.embedUrl}
        target="_blank"
        rel="noopener"
        class="rounded-md px-2.5 py-1.5 text-xs font-medium text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900"
      >
        새 탭에서 열기 ↗
      </a>
    </div>
  </div>

  <div class="embed-frame">
    <iframe
      src={tool.embedUrl}
      title={tool.name}
      loading="lazy"
      allow="clipboard-write"
      allowfullscreen></iframe>
  </div>
</div>

<style>
  .embed-frame {
    width: 100%;
    height: clamp(560px, 80vh, 900px);
  }
  .embed-frame iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }
  /* When the embed goes fullscreen, let the iframe fill the screen. */
  .tool-embed:fullscreen {
    display: flex;
    flex-direction: column;
    background: #fff;
  }
  .tool-embed:fullscreen .embed-frame {
    flex: 1;
    height: auto;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-fullscreen]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const container = btn.closest('.tool-embed');
      container?.requestFullscreen?.();
    });
  });
</script>
