---
import type { Tool } from '../data/tools';
import { t } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  tool: Tool;
  lang: Locale;
}

const { tool, lang } = Astro.props;
const dict = t(lang);
---

<div class="tool-embed overflow-hidden rounded-2xl border border-line bg-surface shadow-sm">
  <div class="flex items-center justify-between gap-2 border-b border-line-subtle px-4 py-2.5">
    <span class="truncate font-mono text-xs text-faint">{tool.slug}</span>
    <div class="flex shrink-0 items-center gap-1">
      <button
        type="button"
        data-fullscreen
        class="rounded-md px-2.5 py-1.5 text-xs font-medium text-muted transition-colors hover:bg-line-subtle hover:text-fg"
      >
        {dict.embedFullscreen}
      </button>
      <a
        href={tool.embedUrl}
        target="_blank"
        rel="noopener"
        class="rounded-md px-2.5 py-1.5 text-xs font-medium text-muted transition-colors hover:bg-line-subtle hover:text-fg"
      >
        {dict.embedNewTab}
      </a>
    </div>
  </div>

  <div class="embed-frame">
    {/* The Claude artifact iframe's inner frame skips rendering when it loads
        outside the viewport. We defer src assignment until IntersectionObserver
        sees the iframe entering the viewport so the inner frame measures itself
        as visible and renders. */}
    <iframe
      data-deferred-src={tool.embedUrl}
      title={tool.name[lang]}
      width="100%"
      height="600"
      frameborder="0"
      allow="clipboard-write"
      allowfullscreen></iframe>
  </div>
</div>

<style>
  .embed-frame {
    width: 100%;
    height: clamp(560px, 80vh, 900px);
  }
  .embed-frame iframe {
    display: block;
    width: 100%;
    height: 100%;
    border: 0;
  }
  /* When the embed goes fullscreen, let the iframe fill the screen. */
  .tool-embed:fullscreen {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
  }
  .tool-embed:fullscreen .embed-frame {
    flex: 1;
    height: auto;
  }
</style>

<script>
  // Defer setting iframe src until the iframe enters the viewport. Without
  // this, claude.site's inner iframe checks its visibility on first load and
  // skips rendering when it's offscreen, leaving the embed blank.
  const observer = new IntersectionObserver(
    (entries, obs) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        const iframe = entry.target as HTMLIFrameElement;
        const src = iframe.dataset.deferredSrc;
        if (src && !iframe.src) {
          iframe.src = src;
        }
        obs.unobserve(iframe);
      }
    },
    { rootMargin: '200px' },
  );
  document
    .querySelectorAll<HTMLIFrameElement>('iframe[data-deferred-src]')
    .forEach((iframe) => observer.observe(iframe));

  document.querySelectorAll<HTMLButtonElement>('[data-fullscreen]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const container = btn.closest('.tool-embed');
      container?.requestFullscreen?.();
    });
  });
</script>
