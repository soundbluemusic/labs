---
import type { Tool } from '../data/tools';
import { t } from '../i18n/utils';
import { localizePath } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  tool: Tool;
  lang: Locale;
}

const { tool, lang } = Astro.props;
const dict = t(lang);
const href = localizePath(`/tools/${tool.slug}`, lang);
---

<a
  href={href}
  class="group flex flex-col rounded-2xl border border-line bg-surface p-6 shadow-sm transition hover:-translate-y-0.5 hover:border-accent-line hover:shadow-md"
>
  <div class="mb-3 flex flex-wrap items-center gap-2">
    <span class="rounded-full bg-line-subtle px-2.5 py-1 text-xs font-medium text-muted">
      {tool.category[lang]}
    </span>
    {
      tool.requiresLogin && (
        <span class="rounded-full bg-fg px-2.5 py-1 text-xs font-medium text-accent-fg">
          {dict.cardRequiresLogin}
        </span>
      )
    }
  </div>

  <h2 class="text-lg font-semibold text-fg">
    {tool.name[lang]}
  </h2>
  <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{tool.tagline[lang]}</p>

  <span class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-accent">
    {dict.cardOpen}
    <svg
      class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
      viewBox="0 0 20 20"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      aria-hidden="true"
    >
      <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </span>
</a>
